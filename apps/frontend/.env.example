# Copy to apps/frontend/.env and fill in real values.
# CRA bakes REACT_APP_* into the build at `npm run build` time, so set these
# BEFORE building for production.

# CRA dev server port (only used by `npm start`).
PORT=3000

# Public URL of the backend, as seen by the browser.
#   Local dev:   http://localhost:3001
#   Production:  https://your-domain.com/api   (if nginx proxies /api → backend)
#   Production:  http://VPS_IP:3001            (if backend is exposed directly)
REACT_APP_API_URL=http://localhost:3001

# Admin route prefix (obscures the admin URL).
REACT_APP_PANEL_PREFIX=x-panel-5661

# localStorage keys used to persist the JWT and the cached user object.
REACT_APP_AUTH_TOKEN_KEY=analyze_data_agent_auth
REACT_APP_AUTH_USER_KEY=analyze_data_agent_user
