{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@sync-project/shared": "file:../../packages/shared",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-data-grid": "^9.0.1",
    "@tanstack/react-query": "^5.99.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.15.0",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.14.0",
    "react-scripts": "5.0.1",
    "typescript": "~5.7.3",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "node node_modules/react-scripts/bin/react-scripts.js start",
    "test": "node node_modules/react-scripts/bin/react-scripts.js test",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "npm run build --prefix ../../packages/shared && node ./node_modules/typescript/lib/tsc.js --noEmit -p tsconfig.json",
    "build:app": "node node_modules/react-scripts/bin/react-scripts.js build",
    "ci:check": "npm run lint && npm run build:app",
    "build": "npm run build --prefix ../../packages/shared && npm run build:app",
    "eject": "node node_modules/react-scripts/bin/react-scripts.js eject"
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
