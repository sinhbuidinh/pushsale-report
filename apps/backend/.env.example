# Copy to apps/backend/.env and fill in real values. Never commit the real file.

# --- Process ---
PORT=3001
HOST=0.0.0.0
# IANA zone for cron + log timestamps + daily log filename (UTC+7 = Asia/Ho_Chi_Minh)
APP_TIMEZONE=Asia/Ho_Chi_Minh
# Append [LEVEL][CONTEXT] log lines into logs/YYYY-MM-DD.log
ENABLE_LOG=true

# --- Daily PushSale sync cron ---
# minute hour day month weekday — default: 00:05 in APP_TIMEZONE
SYNC_CRON_EXPRESSION="5 0 * * *"
# Min ms between PushSale page requests (matches their per-token throttle).
PUSHSALE_REQUEST_INTERVAL_MS=61000

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=sync_app
DB_PASSWORD=change-me
DB_DATABASE=hungviet_smarthome
# Production: set to false after the schema is stable (prevents accidental ALTER/DROP).
DB_SYNCHRONIZE=true

# --- Auth ---
# REQUIRED. Generate with: openssl rand -base64 48
JWT_SECRET=
# Short-lived access token (ms-compatible: 15m, 1h). Stolen tokens expire quickly.
JWT_ACCESS_EXPIRES_IN=15m
# Long-lived refresh token stored server-side (hashed). Rotated on each refresh.
JWT_REFRESH_EXPIRES_IN=7d
# HttpOnly cookie for refresh token (not exposed to JavaScript).
JWT_REFRESH_COOKIE_NAME=refresh_token
# Cookie path — use /api when nginx proxies backend under /api.
JWT_REFRESH_COOKIE_PATH=/
# lax | strict | none (none requires COOKIE_SECURE=true and HTTPS)
COOKIE_SAME_SITE=lax
# true in production HTTPS; false for local http://localhost dev
COOKIE_SECURE=false
# Initial password for admin seed (auth) and when sync auto-creates users from PushSale.
DEFAULT_USER_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_PASSWORD=admin@2026

# --- CORS ---
# Empty/unset or "*" = allow all. Otherwise comma-separated origins, e.g.
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=

# --- PushSale ---
PUSHSALE_CLIENT_ID=
PUSHSALE_API_TOKEN=
PUSHSALE_API_URL=https://pushsale.vn/v1/getdata

# --- Meta / Facebook Ads ---
META_GRAPH_API_VERSION=v25.0
META_APP_ID=
META_BUSINESS_ID=
META_ACCESS_TOKEN=
# Daily cron: sync yesterday's ad spend for all marketing users (default 00:15 APP_TIMEZONE).
FACEBOOK_ADS_SYNC_CRON_EXPRESSION="15 0 * * *"
# Pause between Meta insights API calls per ad account (ms).
FACEBOOK_ADS_AD_ACCOUNT_INTERVAL_MS=5000
